@model LibraryManagementSystem.Models.HomeViewModel
@{
    ViewData["Title"] = "Welcome";
}

<!-- The hero now uses a CSS background image. Replace `/images/home-library.svg` with your uploaded image (e.g., `/images/home-library.jpg`). -->
<div class="home-hero" role="img" aria-label="Cozy home library">
    <div class="home-hero-overlay">
        <div class="home-hero-content">
            <h1>Welcome to Home Library</h1>
            <p>Use the <a href="/Books">Books</a> page to manage your personal library. Search by title, ISBN, or location.</p>
            <p class="lead">Browse, add, and manage your books.</p>
        </div>
    </div>
</div>

<!-- Statistics Section -->
<div class="container mt-5">
    <div class="row">
        <div class="col-12">
            <h2 class="mb-4">Book Statistics by Location</h2>
        </div>
    </div>

    <div class="row">
        <!-- Total Books Card -->
        <div class="col-md-3 mb-4">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h5 class="card-title text-muted">Total Books</h5>
                    <h2 class="display-4 text-primary">@Model.TotalBooks</h2>
                </div>
            </div>
        </div>

        <!-- Location Statistics Cards -->
        @foreach (var stat in Model.LocationStatistics)
        {
            var cardClass = stat.Location switch
            {
                LibraryManagementSystem.Models.Location.Home => "border-success",
                LibraryManagementSystem.Models.Location.Work => "border-info",
                LibraryManagementSystem.Models.Location.Loaned => "border-warning",
                LibraryManagementSystem.Models.Location.Unknown => "border-secondary",
                _ => "border-secondary"
            };

            var textColor = stat.Location switch
            {
                LibraryManagementSystem.Models.Location.Home => "text-success",
                LibraryManagementSystem.Models.Location.Work => "text-info",
                LibraryManagementSystem.Models.Location.Loaned => "text-warning",
                LibraryManagementSystem.Models.Location.Unknown => "text-secondary",
                _ => "text-secondary"
            };

            <div class="col-md-3 mb-4">
                <div class="card @cardClass shadow-sm">
                    <div class="card-body text-center">
                        <h5 class="card-title @textColor fw-bold">@stat.LocationName</h5>
                        <h2 class="display-4">@stat.Count</h2>
                        <p class="text-muted mb-0">books</p>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Chart Section (Optional) -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Distribution</h5>
                    <div class="progress" style="height: 30px;">
                        @{
                            var total = Model.TotalBooks > 0 ? Model.TotalBooks : 1;
                        }
                        @foreach (var stat in Model.LocationStatistics)
                        {
                            var percentage = (stat.Count * 100.0 / total);
                            var bgClass = stat.Location switch
                            {
                                LibraryManagementSystem.Models.Location.Home => "bg-success",
                                LibraryManagementSystem.Models.Location.Work => "bg-info",
                                LibraryManagementSystem.Models.Location.Loaned => "bg-warning",
                                LibraryManagementSystem.Models.Location.Unknown => "bg-secondary",
                                _ => "bg-secondary"
                            };

                            <div class="progress-bar @bgClass" role="progressbar" 
                                 style="width: @percentage.ToString("F1")%" 
                                 aria-valuenow="@stat.Count" 
                                 aria-valuemin="0" 
                                 aria-valuemax="@Model.TotalBooks">
                                @if (percentage > 10)
                                {
                                    <span>@stat.LocationName (@stat.Count)</span>
                                }
                            </div>
                        }
                    </div>
                    <div class="mt-3">
                        @foreach (var stat in Model.LocationStatistics)
                        {
                            var percentage = (stat.Count * 100.0 / total);
                            var colorClass = stat.Location switch
                            {
                                LibraryManagementSystem.Models.Location.Home => "text-success",
                                LibraryManagementSystem.Models.Location.Work => "text-info",
                                LibraryManagementSystem.Models.Location.Loaned => "text-warning",
                                LibraryManagementSystem.Models.Location.Unknown => "text-secondary",
                                _ => "text-secondary"
                            };

                            <span class="badge bg-light @colorClass me-2">
                                <strong>@stat.LocationName:</strong> @stat.Count (@percentage.ToString("F1")%)
                            </span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .home-hero { 
        width: 100%; 
        height: 100vh; 
        min-height: 100vh; 
        background-image: url('/images/cover-page-home-library-1000x506.jpg'); 
        background-size: cover; 
        background-position: center; 
        background-repeat: no-repeat; 
        background-attachment: fixed; 
        border-radius: 0; 
        box-shadow: none; 
        position: relative; 
        overflow: hidden; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
    }
    .home-hero-overlay { 
        position: absolute; inset: 0; 
        background: linear-gradient(180deg, rgba(0,0,0,0.35), rgba(0,0,0,0.25));
        display:flex; align-items:center; justify-content:center;
    }
    .home-hero-content { color: #fff; text-align:center; padding: 2rem; max-width: 900px; margin: 0 1rem; }
    .home-hero-content h1 { margin:0 0 0.5rem 0; font-size: 3rem; font-weight:700; }
    .home-hero-content p { margin:0.25rem 0; }
    .home-hero-content .lead { margin-top:0.75rem; opacity:0.95; }
    @Html.Raw("@media (max-width:600px){ .home-hero{height:100vh;} .home-hero-content h1{font-size:2rem;} .home-hero-content h2{font-size:1.4rem;} }")
</style>

<style>
    .home-hero { margin-top: 0; display: block; }
    .home-hero-img { width: 100%; max-width: 1000px; height: auto; border-radius: 8px; box-shadow: 0 6px 18px rgba(0,0,0,0.08); }
</style>